rules_version = '2';

// Verdana Firestore security rules.
// Auth is handled by Clerk (not Firebase Auth), so privileged writes go through
// the server (Admin SDK, which bypasses these rules). Client access is read-only
// for public social data. Tighten per-collection as the social features land.

service cloud.firestore {
  match /databases/{database}/documents {

    // Public, read-only social graph for the client SDK.
    match /profiles/{userId} {
      allow read: if true;
      allow write: if false; // server-only (Admin SDK)
    }

    match /contributions/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /posts/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /forumThreads/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /challenges/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Everything else: locked down by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
