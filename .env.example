# Verdana environment variables
# Copy to .env.local and fill in. The app runs fully in DEMO MODE with none set.
# Stack: Clerk (auth, Google) + Firebase Firestore (database) + Vercel (host).

# --- Clerk (authentication: Google sign-in) ---
# Clerk dashboard → API Keys. Enable Google in Clerk → SSO Connections.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/signup"
# Admin access: a Clerk user whose publicMetadata = { "role": "admin" }, OR any
# email listed here (comma-separated). Admins are routed straight to /admin.
ADMIN_EMAILS=""

# --- Firebase Firestore (database) ---
# Firebase console → Project settings → your Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# --- Firebase Admin (server-side reads) ---
# Firebase console → Project settings → Service accounts → Generate new private key.
# On Vercel, paste the private key with literal \n (the app converts them back).
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# --- AI photo review for Quests (pick ONE provider, or leave blank for demo) ---
# Uploaded quest photos are checked by a vision AI, then discarded (never stored).
# Any OpenAI-compatible provider works — set base URL + key + a vision model.
# FREE options (no cost):
#
#   Groq  (free, fast, no card — recommended)   key: https://console.groq.com/keys
#     AI_VISION_BASE_URL="https://api.groq.com/openai/v1"
#     AI_VISION_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"
#
#   Google Gemini  (free tier)                  key: https://aistudio.google.com/apikey
#     AI_VISION_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
#     AI_VISION_MODEL="gemini-2.0-flash"
#
#   OpenRouter  (has :free vision models)       key: https://openrouter.ai/keys
#     AI_VISION_BASE_URL="https://openrouter.ai/api/v1"
#     AI_VISION_MODEL="meta-llama/llama-3.2-11b-vision-instruct:free"
#
#   xAI Grok  (paid; free credits vary)         key: https://console.x.ai
#     AI_VISION_BASE_URL="https://api.x.ai/v1"
#     AI_VISION_MODEL="grok-2-vision-1212"
#
# (If a model id 404s, grab the current vision model id from the provider's docs.)
AI_VISION_BASE_URL=""
AI_VISION_API_KEY=""
AI_VISION_MODEL=""

# Alternative: Anthropic Claude (best quality, paid). Used ONLY when the
# AI_VISION_* vars above are empty. platform.claude.com → API Keys.
ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-opus-4-8"
