# Verdana environment variables
# Copy to .env.local and fill in. The app runs fully in DEMO MODE with none of
# these set.

# --- Clerk (authentication: Google sign-in) ---
# Found in Clerk dashboard → API Keys. Enable Google in Clerk → SSO Connections.
# When set, the app uses real Clerk auth; otherwise sign-in is simulated (demo).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Route Clerk to Verdana's own pages
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/signup"
# Admin access is granted to a Clerk user whose publicMetadata = { "role": "admin" }

# --- Supabase (database) ---
# Found in Supabase dashboard → Project Settings → API.
# Database connection is scaffolded; used for persisting profiles/contributions.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# --- Database (V1 legacy — Prisma / PostgreSQL + PostGIS) ---
# Only needed if you wire up the legacy commerce pages to Prisma.
DATABASE_URL="postgresql://user:password@localhost:5432/verdana?schema=public"

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Maps (Mapbox or Google Maps) ---
NEXT_PUBLIC_MAPBOX_TOKEN=""

# --- Satellite imagery / monitoring ---
PLANET_API_KEY=""
COPERNICUS_CLIENT_ID=""
COPERNICUS_CLIENT_SECRET=""

# --- Email / notifications ---
SENDGRID_API_KEY=""
